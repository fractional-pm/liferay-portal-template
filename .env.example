# ═══════════════════════════════════════════════════════════════════════════
# Liferay Community Portal — One-Click Deployment Configuration
# Copy this to .env and edit before running: docker compose up -d
# ═══════════════════════════════════════════════════════════════════════════

# ── Portal ────────────────────────────────────────────────────────────────
PORTAL_DOMAIN=portal.example.com
PORTAL_COMPANY_NAME=Acme Corp
PORTAL_ADMIN_EMAIL=admin@example.com
PORTAL_ADMIN_SCREEN_NAME=admin

# ── Database ──────────────────────────────────────────────────────────────
POSTGRES_DB=lportal
POSTGRES_USER=liferay
POSTGRES_PASSWORD=ChangeMeNow2026!

# ── JVM ───────────────────────────────────────────────────────────────────
LIFERAY_JVM_XMS=1g
LIFERAY_JVM_XMX=2g
ELASTICSEARCH_HEAP=512m

# ── Theme Branding ────────────────────────────────────────────────────────
BRAND_NAME=Acme Corp
THEME_ID=acmetheme
THEME_DISPLAY_NAME=Acme Theme

# Colors (Gartner Blue preset — change to match your brand)
COLOR_PRIMARY=#00395E
COLOR_PRIMARY_LIGHT=#0072CE
COLOR_PRIMARY_LIGHTER=#4DA3E5
COLOR_PRIMARY_LIGHTEST=#E8F4FD
COLOR_SECONDARY=#1A1A2E
COLOR_ACCENT=#0072CE

# Typography
FONT_IMPORT_URL=https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@300;400;500;600;700&display=swap
FONT_FAMILY=IBM Plex Sans
FONT_SIZE_BASE=0.875rem

# Layout: sharp | soft | round
LAYOUT_STYLE=sharp
CONTENT_MAX_WIDTH=1584px

# ── Pages (comma-separated: Name|/url|portlet-id) ────────────────────────
SITE_PAGES=Home|/home|com_liferay_journal_content_web_portlet_JournalContentPortlet,Products|/products|com_liferay_journal_content_web_portlet_JournalContentPortlet,Solutions|/solutions|com_liferay_journal_content_web_portlet_JournalContentPortlet,Use Cases|/use-cases|com_liferay_journal_content_web_portlet_JournalContentPortlet,Industries|/industries|com_liferay_journal_content_web_portlet_JournalContentPortlet,Blog|/blog|com_liferay_blogs_web_portlet_BlogsPortlet,Knowledge Base|/knowledge-base|com_liferay_journal_content_web_portlet_JournalContentPortlet,Documents|/documents-library|com_liferay_document_library_web_portlet_DLPortlet

# ── Footer Columns (pipe-separated: Heading|Link:URL|...) ────────────────
FOOTER_COL_1=Products|AI Platform:#|Data Engine:#|Cloud Suite:#|Developer Tools:#
FOOTER_COL_2=Solutions|Digital Transformation:#|Intelligent Automation:#|Enterprise Analytics:#|Hybrid Cloud:#
FOOTER_COL_3=Industries|Financial Services:#|Healthcare:#|Manufacturing:#|Public Sector:#
FOOTER_COL_4=Use Cases|Predictive Ops:#|Customer Intel:#|Supply Chain:#|Compliance:#
FOOTER_COL_5=Who We Serve|Enterprise:#|Mid-Market:#|Partners:#|Developers:#
FOOTER_COL_6=Company|About Us:#|Leadership:#|Research:#|Contact:#

# ── SMTP (Optional) ──────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=true

# ── SSL ───────────────────────────────────────────────────────────────────
# Set to "true" if you have certs at /etc/letsencrypt/live/$PORTAL_DOMAIN/
SSL_ENABLED=false
